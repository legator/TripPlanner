# Map provider: 'google' (default) or 'here'
# Controls which mapping service is used for routing, places, and the map UI
NEXT_PUBLIC_MAP_PROVIDER=google
MAP_PROVIDER=google

# Google Maps Platform API Key (required when MAP_PROVIDER=google)
# Required APIs: Maps JavaScript API, Directions API, Places API, Geocoding API
# Get your key at: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# HERE Maps API Key (required when MAP_PROVIDER=here)
# Uses HERE Routing API v8, Browse API, Autosuggest, Reverse Geocoding, and Maps JS SDK
# Get your free key (30k req/month) at: https://platform.here.com
NEXT_PUBLIC_HERE_API_KEY=your_here_api_key_here
HERE_API_KEY=your_here_api_key_here

# Vercel KV (optional — for collaborative short-link sharing)
# Create a KV database in the Vercel dashboard and link it to your project.
# These env vars are injected automatically when using Vercel, or set manually for local dev.
# https://vercel.com/docs/storage/vercel-kv/quickstart
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
